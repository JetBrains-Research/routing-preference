 from minisweagent.exceptions import Submitted
 from minisweagent.utils.serialize import recursive_merge
 
+_READ_COMMANDS = {"cat", "head", "tail", "less", "more", "sed", "awk", "nl", "view", "bat"}
+_PATTERN_COMMANDS = {"sed", "awk", "grep"}
+_PATH_RE = re.compile(r"^[a-zA-Z0-9_./\-]+$")
+
+
+def _normalize_repo_path(path: str, cwd: str = "/workspace") -> str | None:
+    if path in {"", ".", "./", ".."}:
+        return None
+    if path.startswith("/tmp/"):
+        return None
+    if Path(path).is_absolute():
+        workspace = cwd.rstrip("/") + "/"
+        if not path.startswith(workspace):
+            return None
+        path = path.removeprefix(workspace)
+    path = path.removeprefix("./")
+    parts = path.split("/")
+    if any(part in {"", ".", ".."} for part in parts):
+        return None
+    return path
+
+
+def _extract_grep_files(output: str, cwd: str = "/workspace") -> list[str]:
+    paths = []
+    for line in output.splitlines():
+        if ":" not in line:
+            continue
+        raw_path = line.split(":", 1)[0]
+        if raw_path.isdigit():
+            continue
+        if not _PATH_RE.match(raw_path):
+            continue
+        path = _normalize_repo_path(raw_path, cwd)
+        if path and path not in paths:
+            paths.append(path)
+    return paths
+
+
+def _extract_exposed_files(command: str, output: str = "", cwd: str = "/workspace") -> tuple[list[str], list[str]]:
+    """Extract file paths from commands that expose file content to the agent."""
+    paths = []
+    grep_paths = []
+    for segment in re.split(r"(?:&&|\|\||;|\|)", command):
+        try:
+            tokens = shlex.split(segment.strip())
+        except ValueError:
+            continue
+        if not tokens:
+            continue
+        cmd_name = Path(tokens[0]).name
+        if cmd_name == "grep":
+            for path in _extract_grep_files(output, cwd):
+                if path not in grep_paths:
+                    grep_paths.append(path)
+            continue
+        if cmd_name not in _READ_COMMANDS:
+            continue
+        if ">" in segment:
+            continue
+        if cmd_name == "sed" and any(a.startswith("-i") for a in tokens[1:]):
+            continue
+        positionals = [a for a in tokens[1:] if a and not a.startswith("-")]
+        if cmd_name in _PATTERN_COMMANDS and positionals:
+            positionals = positionals[1:]
+        for p in positionals:
+            if not _PATH_RE.match(p):
+                continue
+            path = _normalize_repo_path(p, cwd)
+            if path and path not in paths:
+                paths.append(path)
+    return paths, grep_paths
+
 
